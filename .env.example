# Strategy report verifier production configuration.
# Copy this file to .env on Windows or Linux. Never commit real API keys.

# Shared fallback endpoint/key. OpenRouter-compatible chat-completions APIs work here.
STRATEGY_VERIFIER_BASE_URL=https://openrouter.ai/api/v1
STRATEGY_VERIFIER_API_KEY=

# LLM channel. Overrides the shared values when set.
STRATEGY_VERIFIER_LLM_BASE_URL=
STRATEGY_VERIFIER_LLM_API_KEY=
STRATEGY_VERIFIER_LLM_FLASH_MODEL=deepseek/deepseek-v4-flash
STRATEGY_VERIFIER_LLM_PRO_MODEL=deepseek/deepseek-v4-pro

# VLM channel for chart/visual QA. Keep separate from LLM because latency/cost/provider may differ.
STRATEGY_VERIFIER_VLM_BASE_URL=
STRATEGY_VERIFIER_VLM_API_KEY=
STRATEGY_VERIFIER_VLM_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# Retry behavior for OpenRouter-compatible calls.
OPENROUTER_RETRIES=3
OPENROUTER_BACKOFF_SECONDS=3
